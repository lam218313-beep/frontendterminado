{
  "_meta": {
    "name": "Product Hero",
    "version": "1.0.0",
    "description": "Template para generación de productos tipo Hero/E-commerce",
    "format": "producto",
    "required_inputs": ["PRODUCT_IMAGE", "PROMPT"],
    "optional_inputs": ["COMPOSITION_REF", "SURFACE_TEXTURE", "LIGHT_REF"]
  },
  "3": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "{{PRODUCT_IMAGE}}"
    },
    "_comment": "Carga la imagen del producto PNG sin fondo"
  },
  "4": {
    "class_type": "UNETLoader",
    "inputs": {
      "unet_name": "flux1-dev.safetensors",
      "weight_dtype": "fp8_e4m3fn"
    },
    "_comment": "Carga FLUX.1 dev model"
  },
  "5": {
    "class_type": "DualCLIPLoader",
    "inputs": {
      "clip_name1": "clip_l.safetensors",
      "clip_name2": "t5xxl_fp16.safetensors",
      "type": "flux"
    },
    "_comment": "Carga los text encoders para FLUX"
  },
  "6": {
    "class_type": "VAELoader",
    "inputs": {
      "vae_name": "ae.safetensors"
    },
    "_comment": "VAE de FLUX"
  },
  "10": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "{{PROMPT}}",
      "clip": ["5", 0]
    },
    "_comment": "Prompt positivo"
  },
  "11": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "{{NEGATIVE_PROMPT}}",
      "clip": ["5", 0]
    },
    "_comment": "Prompt negativo"
  },
  "20": {
    "class_type": "EmptySD3LatentImage",
    "inputs": {
      "width": "{{WIDTH}}",
      "height": "{{HEIGHT}}",
      "batch_size": 1
    },
    "_comment": "Latent vacío para generación"
  },
  "30": {
    "class_type": "KSampler",
    "inputs": {
      "seed": "{{SEED}}",
      "steps": "{{STEPS}}",
      "cfg": "{{CFG_SCALE}}",
      "sampler_name": "euler",
      "scheduler": "simple",
      "denoise": 1.0,
      "model": ["4", 0],
      "positive": ["10", 0],
      "negative": ["11", 0],
      "latent_image": ["20", 0]
    },
    "_comment": "Sampler principal"
  },
  "40": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["30", 0],
      "vae": ["6", 0]
    },
    "_comment": "Decodifica latent a imagen"
  },
  "50": {
    "class_type": "ImageCompositeMasked",
    "inputs": {
      "destination": ["40", 0],
      "source": ["3", 0],
      "x": 0,
      "y": 0,
      "resize_source": true
    },
    "_comment": "Composita el producto real sobre el fondo generado"
  },
  "60": {
    "class_type": "SaveImage",
    "inputs": {
      "filename_prefix": "pixely_product_hero",
      "images": ["50", 0]
    },
    "_comment": "Guarda la imagen final"
  }
}
